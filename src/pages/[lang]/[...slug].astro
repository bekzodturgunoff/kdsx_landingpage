---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import MobileHighlights from '../../components/MobileHighlights.astro';
import BusinessSection from '../../components/BusinessSection.astro';
import FeaturesSection from '../../components/FeaturesSection.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Testimonials from '../../components/Testimonials.astro';
import PricingTable from '../../components/PricingTable.astro';
import FAQ from '../../components/FAQ.astro';
import { createT } from '../../i18n';

const supportedLangs = ['en', 'ru', 'ko', 'uz'] as const;
const validPages = ['home', 'features', 'pricing', 'faq', 'privacy', 'terms'] as const;

type SupportedLang = (typeof supportedLangs)[number];
type ValidPage = (typeof validPages)[number];

const { lang, slug } = Astro.params;
const langCode = String(lang || '');

if (!supportedLangs.includes(langCode as SupportedLang)) {
  return Astro.redirect('/en', 302);
}

const slugPath = Array.isArray(slug) ? slug.join('/') : (slug || '');
const page = (slugPath || 'home') as ValidPage;
const t = createT(langCode);

if (!validPages.includes(page)) {
  return new Response('Not found', { status: 404 });
}
---

<Layout lang={langCode}>
  <Header />

  {page === 'home' && (
    <main class="space-y-0">
      <Hero />
      <MobileHighlights />
      <div class="hidden md:block">
        <BusinessSection />
        <FeaturesSection />
        <HowItWorks />
        <Testimonials />
        <PricingTable>
          <Fragment slot="faq">
            <FAQ />
          </Fragment>
        </PricingTable>
      </div>
    </main>
  )}

  {page === 'features' && (
    <main class="space-y-0">
      <BusinessSection />
      <FeaturesSection />
      <HowItWorks />
    </main>
  )}

  {page === 'pricing' && (
    <main class="space-y-0">
      <PricingTable />
    </main>
  )}

  {page === 'faq' && (
    <main class="space-y-0">
      <FAQ />
    </main>
  )}

  {page === 'privacy' && (
    <main class="w-full px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <section class="max-w-4xl mx-auto section-shell px-4 sm:px-8 py-10 text-brand-text dark:text-brand-text-dark">
        <span class="badge-pill" data-i18n="privacyBadge">{t('privacyBadge')}</span>
        <h1 class="mt-4 text-3xl sm:text-4xl font-semibold tracking-tight" data-i18n="privacyHeading">{t('privacyHeading')}</h1>
        <p class="mt-3 text-base text-brand-text/80 dark:text-brand-text-dark/75" data-i18n="privacyIntro">
          {t('privacyIntro')}
        </p>

        <div class="mt-8 space-y-6 text-base leading-relaxed">
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="privacySection1Title">{t('privacySection1Title')}</h2>
            <p class="mt-2" data-i18n="privacySection1Body">
              {t('privacySection1Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="privacySection2Title">{t('privacySection2Title')}</h2>
            <p class="mt-2" data-i18n="privacySection2Body">
              {t('privacySection2Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="privacySection3Title">{t('privacySection3Title')}</h2>
            <p class="mt-2" data-i18n="privacySection3Body">
              {t('privacySection3Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="privacySection4Title">{t('privacySection4Title')}</h2>
            <p class="mt-2" data-i18n="privacySection4Body">
              {t('privacySection4Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="privacySection5Title">{t('privacySection5Title')}</h2>
            <p class="mt-2" data-i18n="privacySection5Body">
              {t('privacySection5Body')}
            </p>
          </div>
        </div>
      </section>
    </main>
  )}

  {page === 'terms' && (
    <main class="w-full px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <section class="max-w-4xl mx-auto section-shell px-4 sm:px-8 py-10 text-brand-text dark:text-brand-text-dark">
        <span class="badge-pill" data-i18n="termsBadge">{t('termsBadge')}</span>
        <h1 class="mt-4 text-3xl sm:text-4xl font-semibold tracking-tight" data-i18n="termsHeading">{t('termsHeading')}</h1>
        <p class="mt-3 text-base text-brand-text/80 dark:text-brand-text-dark/75" data-i18n="termsIntro">
          {t('termsIntro')}
        </p>

        <div class="mt-8 space-y-6 text-base leading-relaxed">
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="termsSection1Title">{t('termsSection1Title')}</h2>
            <p class="mt-2" data-i18n="termsSection1Body">
              {t('termsSection1Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="termsSection2Title">{t('termsSection2Title')}</h2>
            <p class="mt-2" data-i18n="termsSection2Body">
              {t('termsSection2Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="termsSection3Title">{t('termsSection3Title')}</h2>
            <p class="mt-2" data-i18n="termsSection3Body">
              {t('termsSection3Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="termsSection4Title">{t('termsSection4Title')}</h2>
            <p class="mt-2" data-i18n="termsSection4Body">
              {t('termsSection4Body')}
            </p>
          </div>
          <div>
            <h2 class="text-2xl font-semibold" data-i18n="termsSection5Title">{t('termsSection5Title')}</h2>
            <p class="mt-2" data-i18n="termsSection5Body">
              {t('termsSection5Body')}
            </p>
          </div>
        </div>
      </section>
    </main>
  )}
</Layout>
