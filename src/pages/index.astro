---
const acceptLang = Astro.request.headers.get("accept-language") || "";
const ipCountry = Astro.request.headers.get("x-vercel-ip-country") || "";

let targetLang = "en";

// Simple IP country mapping
if (ipCountry === "KR") {
  targetLang = "ko";
} else if (ipCountry === "UZ") {
  targetLang = "uz";
} else if (ipCountry === "RU" || ipCountry === "BY" || ipCountry === "KZ") {
  targetLang = "ru";
} else {
  // Fallback to browser language
  const prioritized = acceptLang.split(",").map(lang => lang.split(";")[0].trim().toLowerCase() || "");
  for (const lang of prioritized) {
    if (lang.startsWith("ko")) {
      targetLang = "ko";
      break;
    } else if (lang.startsWith("uz")) {
      targetLang = "uz";
      break;
    } else if (lang.startsWith("ru")) {
      targetLang = "ru";
      break;
    } else if (lang.startsWith("en")) {
      targetLang = "en";
      break;
    }
  }
}

return Astro.redirect(`/${targetLang}`, 302);
---