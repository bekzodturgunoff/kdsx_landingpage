---
import {createT} from "../i18n";

const supportedLangs = ["en", "ru", "ko", "uz"] as const;
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const currentLang = supportedLangs.includes((pathSegments[0] || "") as (typeof supportedLangs)[number]) ? pathSegments[0] : "en";
const t = createT(currentLang);

const trialAPIBaseURL = (process.env.PUBLIC_TRIAL_API_BASE_URL || "http://localhost:3000").replace(/\/$/, "");
const dashAppURL = process.env.PUBLIC_DASH_APP_URL || "http://localhost:3000";
---

<div id="plan-wizard" class="fixed inset-0 z-[60] hidden" data-api-base={trialAPIBaseURL} data-dash-url={dashAppURL}>
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm dark:bg-black/70"></div>
  <div class="relative mx-auto my-10 max-w-lg px-4">
    <div role="dialog" aria-modal="true" aria-labelledby="wizard-title" class="rounded-3xl border bg-[var(--color-brand-bg)] p-6 sm:p-7 md:p-8 shadow-2xl dark:border-white/20">
      <div class="flex items-start justify-between">
        <div>
          <h3 id="wizard-title" class="text-xl font-semibold text-[var(--color-brand-text)]">{t("wizardTitle") || "Start your instant trial"}</h3>
          <p class="mt-1 text-sm text-[var(--color-brand-text)] opacity-70">Create your restaurant and jump into your dashboard in one click.</p>
        </div>
        <button type="button" id="wizard-close" aria-label="Close" class="btn-ghost rounded-full ml-4 h-10 w-10 p-0 text-[var(--color-brand-text)] opacity-70">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M6 18L18 6" stroke-linecap="round"/></svg>
        </button>
      </div>

      <div id="wizard-error" class="mt-4 hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-900 shadow-sm dark:border-red-500/40 dark:bg-red-500/10 dark:text-red-100" role="alert" aria-live="assertive" tabindex="-1">
        <p class="font-semibold">{t("wizardErrorTitle") || "Could not create your trial account."}</p>
        <p class="mt-1">{t("wizardErrorBody") || "Please try again. If this continues, contact support@kdsx.uz."}</p>
      </div>

      <form id="wizard-form" class="mt-6 space-y-4">
        <div>
          <label for="businessName" class="block text-sm font-medium text-[var(--color-brand-text)]">{t("wizardBusinessLabel") || "Business Name"}</label>
          <input id="businessName" name="businessName" type="text" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t("wizardBusinessPlaceholder") || "Your restaurant name"} />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-[var(--color-brand-text)]">{t("wizardEmailLabel") || "Email"}</label>
          <input id="email" name="email" type="email" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t("wizardEmailPlaceholder") || "you@business.com"} />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-[var(--color-brand-text)]">{t("wizardPasswordLabel") || "Password"}</label>
          <input id="password" name="password" type="password" minlength="8" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t("wizardPasswordPlaceholder") || "Minimum 8 characters"} />
        </div>

        <button id="wizard-submit" type="submit" class="btn-solid mt-2 w-full px-6 py-3 text-sm" data-submit-text={t("wizardStartTrial") || "Start Instant Trial"} data-loading-text={t("wizardSubmitting") || "Creating account..."}>{t("wizardStartTrial") || "Start Instant Trial"}</button>
      </form>

      <div id="wizard-loading" class="mt-6 hidden rounded-xl border bg-[var(--color-brand-bg)] p-4 text-sm text-[var(--color-brand-text)] shadow-sm dark:border-white/20">
        <div class="flex items-center gap-3">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-brand-cta border-t-transparent"></span>
          <p>{t("wizardCreatingKitchen") || "Creating your kitchen..."}</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function instantTrialWizard() {
    const modal = document.getElementById("plan-wizard");
    const form = document.getElementById("wizard-form");
    const closeBtn = document.getElementById("wizard-close");
    const submitBtn = document.getElementById("wizard-submit");
    const loadingState = document.getElementById("wizard-loading");
    const errorBox = document.getElementById("wizard-error");

    if (!modal || !form || !submitBtn) return;

    const apiBaseURL = (modal.getAttribute("data-api-base") || "http://localhost:3000").replace(/\/$/, "");
    const dashURL = modal.getAttribute("data-dash-url") || "http://localhost:3000";

    let lastActive = null;
    let keydownHandler = null;

    const showError = () => {
      errorBox?.classList.remove("hidden");
      try {
        errorBox?.focus();
      } catch (_) {}
    };

    const hideError = () => {
      errorBox?.classList.add("hidden");
    };

    const open = () => {
      lastActive = document.activeElement;
      modal.classList.remove("hidden");
      document.documentElement.classList.add("overflow-hidden");
      hideError();
      keydownHandler = (e) => {
        if (e.key === "Escape") close();
      };
      document.addEventListener("keydown", keydownHandler);
      requestAnimationFrame(() => {
        const first = form.querySelector("input");
        first && first.focus && first.focus();
      });
    };

    const close = () => {
      modal.classList.add("hidden");
      document.documentElement.classList.remove("overflow-hidden");
      hideError();
      loadingState?.classList.add("hidden");
      form.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = submitBtn.getAttribute("data-submit-text") || "Start Instant Trial";
      if (keydownHandler) {
        document.removeEventListener("keydown", keydownHandler);
        keydownHandler = null;
      }
      if (lastActive && lastActive.focus) {
        try {
          lastActive.focus();
        } catch (_) {}
      }
    };

    document.addEventListener("click", (e) => {
      const target = e.target instanceof Element ? e.target.closest("[data-plan-trigger]") : null;
      if (!target) return;
      e.preventDefault();
      open();
    });

    closeBtn?.addEventListener("click", close);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) close();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideError();

      const businessName = String(form.businessName?.value || "").trim();
      const email = String(form.email?.value || "").trim().toLowerCase();
      const password = String(form.password?.value || "");

      if (!businessName || !email || password.length < 8) {
        showError();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = submitBtn.getAttribute("data-loading-text") || "Creating account...";
      loadingState?.classList.remove("hidden");

      const firstName = businessName;
      const lastName = "Owner";
      const lang = (document.documentElement.getAttribute("lang") || "en").slice(0, 2);
      const defaultLang = ["en", "ru", "uz", "ko"].includes(lang) ? lang : "en";

      const bootstrapPayload = {
        user: {
          login: email,
          firstName,
          lastName,
          password,
        },
        setting: {
          currency: "USD",
          businessType: "restaurant",
          defaultLang,
        },
        location: {
          name: businessName,
          description: "",
          addressLine1: "",
          addressLine2: "",
          email,
          phone: "",
          websiteURL: "",
          instagramURL: "",
          logoURL: "",
          timeZone: "Asia/Seoul",
          workingFrom: "09:00",
          workingTo: "22:00",
        },
      };

      try {
        const bootstrapRes = await fetch(`${apiBaseURL}/bootstrap`, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(bootstrapPayload),
        });

        if (!bootstrapRes.ok) {
          throw new Error("bootstrap failed");
        }

        const signInRes = await fetch(`${apiBaseURL}/auth.signInWithPassword`, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({login: email, password}),
        });

        if (!signInRes.ok) {
          throw new Error("sign in failed");
        }

        window.location.href = dashURL;
      } catch (_) {
        loadingState?.classList.add("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = submitBtn.getAttribute("data-submit-text") || "Start Instant Trial";
        showError();
      }
    });
  })();
</script>
