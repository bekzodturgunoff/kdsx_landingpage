---
import { createT } from '../i18n';

const supportedLangs = ['en', 'ru', 'ko', 'uz'];
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = supportedLangs.includes(pathSegments[0] || '') ? pathSegments[0] : 'en';
const t = createT(currentLang);
---

<div id="contact-wizard" class="fixed inset-0 z-[60] hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm dark:bg-black/70"></div>
  <div class="relative mx-auto my-10 max-w-lg px-4">
    <div role="dialog" aria-modal="true" class="rounded-3xl border bg-[var(--color-brand-bg)] p-6 sm:p-7 md:p-8 shadow-2xl dark:border-white/20">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <h3 id="contact-title" class="text-xl font-semibold text-[var(--color-brand-text)]"></h3>
          <p id="contact-subtitle" class="mt-1 text-sm text-[var(--color-brand-text)] opacity-70"></p>
        </div>
        <button type="button" id="contact-close" aria-label={t('contactClose')} class="btn-ghost rounded-full ml-4 flex-shrink-0 h-10 w-10 p-0 text-[var(--color-brand-text)] opacity-70">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M6 18L18 6" stroke-linecap="round"/></svg>
        </button>
      </div>

      <div id="contact-error" class="mt-4 hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-900 shadow-sm dark:border-red-500/40 dark:bg-red-500/10 dark:text-red-100" role="alert" aria-live="assertive" tabindex="-1">
        <p class="font-semibold" id="contact-error-title"></p>
        <p class="mt-1" id="contact-error-body"></p>
      </div>

      <form id="contact-form" class="mt-6 space-y-4">
        <div>
          <label for="contact-name" class="block text-sm font-medium text-[var(--color-brand-text)]">{t('contactNameLabel')}</label>
          <input id="contact-name" name="name" type="text" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t('contactNamePlaceholder')} />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-medium text-[var(--color-brand-text)]">{t('contactEmailLabel')}</label>
          <input id="contact-email" name="email" type="email" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t('contactEmailPlaceholder')} />
        </div>
        <div>
          <label for="contact-message" id="contact-message-label" class="block text-sm font-medium text-[var(--color-brand-text)]">{t('contactMessageLabelSales')}</label>
          <textarea id="contact-message" name="message" rows="4" required class="mt-2 w-full rounded-xl border px-4 py-3 shadow-sm outline-none transition-none focus:ring-2 border-brand-cta-text/25 bg-white text-[#1a1a1a] placeholder:text-gray-500 focus:border-brand-cta focus:ring-brand-cta/40 dark:border-white/20 dark:bg-neutral-800 dark:text-white dark:placeholder:text-gray-400" placeholder={t('contactMessagePlaceholderSales')} ></textarea>
        </div>
        <div>
          <label for="contact-image" class="block text-sm font-medium text-[var(--color-brand-text)]">{t('contactImageLabel')}</label>
          <input id="contact-image" name="image" type="file" accept="image/*" class="mt-2 w-full text-sm text-brand-text/80 file:rounded-xl file:border file:px-3 file:py-2 file:bg-white file:text-sm file:font-medium file:border-brand-cta-text/25 dark:file:bg-neutral-800" aria-describedby="contact-image-help" />
          <p id="contact-image-help" class="mt-2 text-xs text-brand-text/60 dark:text-brand-text-dark/60">{t('contactImageHelp')}</p>
          <p id="contact-image-error" class="mt-2 text-xs text-red-600 dark:text-red-400 hidden"></p>
          <div id="contact-image-preview" class="mt-3 hidden">
            <img id="contact-image-thumb" class="rounded-md max-h-36 object-contain border" alt="preview" />
            <div class="mt-2">
              <button type="button" id="contact-image-remove" class="text-xs text-brand-text/80 dark:text-brand-text-dark/80 hover:underline">{t('contactImageRemove') || 'Remove image'}</button>
            </div>
          </div>
        </div>
        <button id="contact-submit" type="submit" class="btn-solid mt-2 w-full px-6 py-3 text-sm" data-submit-text={t('contactSubmitSales')} data-loading-text={t('wizardSubmitting')}>{t('contactSubmitSales')}</button>
      </form>

      <div id="contact-loading" class="mt-6 hidden rounded-xl border bg-[var(--color-brand-bg)] p-4 text-sm text-[var(--color-brand-text)] shadow-sm dark:border-white/20">
        <div class="flex items-center gap-3">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-brand-cta border-t-transparent"></span>
          <p id="contact-loading-text">{t('wizardSubmitting')}</p>
        </div>
      </div>
      <div id="contact-success" class="mt-6 hidden rounded-xl border border-green-200 bg-green-50 p-4 text-sm text-green-900 shadow-sm dark:border-green-500/40 dark:bg-green-500/10 dark:text-green-100">
        <p id="contact-success-title" class="font-semibold"></p>
        <p id="contact-success-body" class="mt-1"></p>
        <div class="mt-4">
          <button type="button" id="contact-success-close" class="inline-flex items-center gap-2 rounded-full border border-brand-cta/35 px-4 py-2 text-sm font-semibold text-brand-text transition-colors duration-200 hover:bg-brand-cta/10">{t('contactSuccessCta')}</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="contact-strings" set:html={JSON.stringify({
  sales: {
    title: t('contactWizardTitleSales'),
    subtitle: t('contactWizardSubtitleSales'),
    messageLabel: t('contactMessageLabelSales'),
    messagePlaceholder: t('contactMessagePlaceholderSales'),
    submit: t('contactSubmitSales')
  },
  support: {
    title: t('contactWizardTitleSupport'),
    subtitle: t('contactWizardSubtitleSupport'),
    messageLabel: t('contactMessageLabelSupport'),
    messagePlaceholder: t('contactMessagePlaceholderSupport'),
    submit: t('contactSubmitSupport')
  },
  common: {
    nameLabel: t('contactNameLabel'),
    namePlaceholder: t('contactNamePlaceholder'),
    emailLabel: t('contactEmailLabel'),
    emailPlaceholder: t('contactEmailPlaceholder'),
    close: t('contactClose'),
    errorTitle: t('contactErrorTitle'),
    errorBody: t('contactErrorBody'),
    successTitle: t('contactSuccessTitle'),
    successBody: t('contactSuccessBody'),
    successCta: t('contactSuccessCta')
  }
})}></script>

<script is:inline>
(function contactWizard(){
  const stringsEl = document.getElementById('contact-strings');
  const strings = stringsEl ? JSON.parse(stringsEl.textContent || '{}') : {};
  const modal = document.getElementById('contact-wizard');
  const closeBtn = document.getElementById('contact-close');
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const loading = document.getElementById('contact-loading');
  const errorBox = document.getElementById('contact-error');
  const errorTitle = document.getElementById('contact-error-title');
  const errorBody = document.getElementById('contact-error-body');
  const titleEl = document.getElementById('contact-title');
  const subtitleEl = document.getElementById('contact-subtitle');
  const messageLabel = document.getElementById('contact-message-label');
  const successBox = document.getElementById('contact-success');
  const successTitle = document.getElementById('contact-success-title');
  const successBody = document.getElementById('contact-success-body');
  const successClose = document.getElementById('contact-success-close');
  let lastActive = null;
  let keydownHandler = null;

  if (!modal || !form || !submitBtn) return;

  // Image preview handling (client-side only)
  const imageInput = document.getElementById('contact-image');
  const imagePreview = document.getElementById('contact-image-preview');
  const imageThumb = document.getElementById('contact-image-thumb');
  const imageError = document.getElementById('contact-image-error');
  const imageRemove = document.getElementById('contact-image-remove');
  let currentObjectUrl = null;

  function clearImagePreview() {
    if (currentObjectUrl) {
      try { URL.revokeObjectURL(currentObjectUrl); } catch (_) {}
      currentObjectUrl = null;
    }
    if (imageThumb) imageThumb.src = '';
    if (imagePreview) imagePreview.classList.add('hidden');
    if (imageError) { imageError.textContent = ''; imageError.classList.add('hidden'); }
    if (imageInput) imageInput.value = '';
  }

  if (imageInput) {
    imageInput.addEventListener('change', (e) => {
      const f = imageInput.files && imageInput.files[0];
      if (!f) { clearImagePreview(); return; }
      if (!f.type || !f.type.startsWith('image/')) {
        if (imageError) { imageError.textContent = strings.common.imageInvalid || 'Selected file is not an image'; imageError.classList.remove('hidden'); }
        clearImagePreview();
        return;
      }
      const maxBytes = 5 * 1024 * 1024; // 5MB
      if (f.size > maxBytes) {
        if (imageError) { imageError.textContent = strings.common.imageTooLarge || 'Image exceeds 5MB'; imageError.classList.remove('hidden'); }
        clearImagePreview();
        return;
      }
      try {
        if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
      } catch (_) {}
      currentObjectUrl = URL.createObjectURL(f);
      if (imageThumb) { imageThumb.src = currentObjectUrl; }
      if (imagePreview) imagePreview.classList.remove('hidden');
      if (imageError) { imageError.textContent = ''; imageError.classList.add('hidden'); }
    });
  }

  if (imageRemove) {
    imageRemove.addEventListener('click', () => { clearImagePreview(); });
  }

  function showError(){
    if (!errorBox) return;
    errorTitle.textContent = strings.common.errorTitle || '';
    errorBody.textContent = strings.common.errorBody || '';
    errorBox.classList.remove('hidden');
    try { errorBox.focus(); } catch (_) {}
  }

  function hideError(){ errorBox?.classList.add('hidden'); }

  function open(type){
    const spec = strings[type] || strings.sales;
    titleEl.textContent = spec.title;
    subtitleEl.textContent = spec.subtitle;
    messageLabel.textContent = spec.messageLabel;
    // set placeholders from translations
    const nameInput = form.querySelector('#contact-name');
    const emailInput = form.querySelector('#contact-email');
    const msgInput = form.querySelector('#contact-message');
    if (nameInput) nameInput.placeholder = strings.common.namePlaceholder || '';
    if (emailInput) emailInput.placeholder = strings.common.emailPlaceholder || '';
    if (msgInput) msgInput.placeholder = spec.messagePlaceholder || '';
    submitBtn.textContent = spec.submit || submitBtn.getAttribute('data-submit-text') || '';
    submitBtn.setAttribute('data-submit-text', spec.submit || submitBtn.getAttribute('data-submit-text') || '');
    lastActive = document.activeElement;
    modal.classList.remove('hidden');
    document.documentElement.classList.add('overflow-hidden');
    hideError();
    if (successBox) successBox.classList.add('hidden');
    keydownHandler = (e) => { if (e.key === 'Escape') close(); };
    document.addEventListener('keydown', keydownHandler);
    requestAnimationFrame(() => { const first = form.querySelector('input'); first && first.focus && first.focus(); });
  }

  function close(){
    modal.classList.add('hidden');
    document.documentElement.classList.remove('overflow-hidden');
    hideError();
    loading?.classList.add('hidden');
    form.classList.remove('hidden');
    if (successBox) successBox.classList.add('hidden');
    submitBtn.disabled = false;
    submitBtn.textContent = submitBtn.getAttribute('data-submit-text') || submitBtn.textContent;
    if (keydownHandler) { document.removeEventListener('keydown', keydownHandler); keydownHandler = null; }
    if (lastActive && lastActive.focus) { try { lastActive.focus(); } catch (_) {} }
    // reset image preview and form fields
    try { clearImagePreview(); } catch (_) {}
    try { form.reset(); } catch (_) {}
  }

  document.addEventListener('click', (e) => {
    const target = e.target instanceof Element ? e.target.closest('[data-contact-trigger]') : null;
    if (!target) return;
    e.preventDefault();
    open(String(target.getAttribute('data-contact-trigger') || 'sales'));
  });

  closeBtn?.addEventListener('click', close);
  modal.addEventListener('click', (e) => { if (e.target === modal) close(); });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    hideError();
    const name = String(form.name?.value || '').trim();
    const email = String(form.email?.value || '').trim();
    const message = String(form.message?.value || '').trim();
    if (!name || !email || !message || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError();
      return;
    }
    submitBtn.disabled = true;
    const loadingText = submitBtn.getAttribute('data-loading-text') || '';
    submitBtn.textContent = loadingText;
    loading?.classList.remove('hidden');
    // Do NOT send anywhere — simulate success and display confirmation
    setTimeout(() => {
      loading?.classList.add('hidden');
      try { form.classList.add('hidden'); } catch (_) {}
      if (successBox) {
        successTitle.textContent = strings.common.successTitle || t('contactSuccessTitle');
        successBody.textContent = strings.common.successBody || t('contactSuccessBody');
        successBox.classList.remove('hidden');
      } else {
        close();
      }
    }, 800);
  });

  // Success close handler
  successClose?.addEventListener('click', () => { close(); });

})();
</script>
