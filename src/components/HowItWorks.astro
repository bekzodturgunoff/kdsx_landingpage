---
import { createT } from '../i18n';

const supportedLangs = ['en', 'ru', 'ko', 'uz'] as const;
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = supportedLangs.includes((pathSegments[0] || '') as (typeof supportedLangs)[number])
  ? pathSegments[0]
  : 'en';
const t = createT(currentLang);
---
<section class="w-full px-2 sm:px-6 py-10 sm:py-16">
  <div class="max-w-6xl mx-auto section-shell px-4 sm:px-9 py-10 sm:py-14">
    <div class="flex flex-col items-center text-center gap-5">
  <span class="badge-pill" data-i18n="howBadge">{t('howBadge')}</span>
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-brand-text dark:text-brand-text-dark" data-i18n="howHeading">
        {t('howHeading')}
      </h2>
  <p class="max-w-3xl text-base sm:text-lg text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="howBody">
        {t('howBody')}
      </p>
    </div>

    <div class="mt-10 grid gap-7 md:grid-cols-3">
      <div class="surface-card p-5 text-left text-brand-text dark:text-brand-text-dark">
        <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta"><span data-i18n="stepLabel">{t('stepLabel')}</span> 01</span>
            <span class="rounded-full bg-brand-cta/20 px-3 py-1 text-xs font-semibold text-brand-cta-text dark:text-brand-cta-text" data-i18n="howStep1Tag">{t('howStep1Tag')}</span>
        </div>
          <h3 class="mt-4 text-2xl font-semibold" data-i18n="howStep1Title">{t('howStep1Title')}</h3>
          <p class="mt-3 text-sm leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="howStep1Body">{t('howStep1Body')}</p>
      </div>

    <div class="surface-card p-5 text-left text-brand-text dark:text-brand-text-dark">
        <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta"><span data-i18n="stepLabel">{t('stepLabel')}</span> 02</span>
            <span class="rounded-full bg-brand-cta/20 px-3 py-1 text-xs font-semibold text-brand-cta-text dark:text-brand-cta-text" data-i18n="howStep2Tag">{t('howStep2Tag')}</span>
        </div>
          <h3 class="mt-4 text-2xl font-semibold" data-i18n="howStep2Title">{t('howStep2Title')}</h3>
          <p class="mt-3 text-sm leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="howStep2Body">{t('howStep2Body')}</p>
      </div>

  <div class="surface-card p-5 text-left text-brand-text dark:text-brand-text-dark">
        <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta"><span data-i18n="stepLabel">{t('stepLabel')}</span> 03</span>
            <span class="rounded-full bg-brand-cta/20 px-3 py-1 text-xs font-semibold text-brand-cta-text dark:text-brand-cta-text" data-i18n="howStep3Tag">{t('howStep3Tag')}</span>
        </div>
          <h3 class="mt-4 text-2xl font-semibold" data-i18n="howStep3Title">{t('howStep3Title')}</h3>
          <p class="mt-3 text-sm leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="howStep3Body">{t('howStep3Body')}</p>
      </div>
    </div>
  </div>
</section>
