---
import { createT, SUPPORTED_LANGS } from '../i18n';
import ContactWizard from './ContactWizard.astro';
import { Image } from 'astro:assets';
import logoDark from '../assets/logo_dark.png';
import logoLight from '../assets/logo_light.png';
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = SUPPORTED_LANGS.includes(pathSegments[0] || '') ? pathSegments[0] : 'en';
const localeBase = `/${currentLang}`;
const t = createT(currentLang);
const currentYear = new Date().getFullYear();
---
<section id="pricing" class="w-full px-2 sm:px-6 py-10 sm:py-16">
  <div class="max-w-6xl mx-auto section-shell px-4 sm:px-9 py-12 sm:py-14">
    <div class="flex flex-col items-center text-center gap-5">
  <span class="badge-pill" data-i18n="pricingBadge">{t('pricingBadge')}</span>
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-brand-text dark:text-brand-text-dark" data-i18n="pricingHeading">
        {t('pricingHeading')}
      </h2>
  <p class="max-w-3xl text-base sm:text-lg text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingBody">
        {t('pricingBody')}
      </p>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="surface-card p-8 text-center text-brand-text dark:text-brand-text-dark">
        <div class="flex items-center justify-center text-sm font-semibold uppercase tracking-[0.35em] text-brand-cta-text dark:text-brand-cta-text-dark">
          <span data-i18n="pricingStarterLabel">{t('pricingStarterLabel')}</span>
        </div>
  <div class="mt-5 text-3xl sm:text-5xl font-bold text-brand-cta-text dark:text-brand-cta-text-dark" data-i18n="pricingStarterPrice">{t('pricingStarterPrice')}</div>
  <div class="mt-2 text-xs font-semibold uppercase tracking-[0.32em] text-brand-cta-text dark:text-brand-cta-text-dark" data-i18n="pricingStarterSubtitle">{t('pricingStarterSubtitle')}</div>
  <p class="mt-4 text-base text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingStarterBody">{t('pricingStarterBody')}</p>
  <ul class="mt-7 space-y-3 text-left text-sm leading-relaxed">
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB1">{t('pricingStarterB1')}</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB2">{t('pricingStarterB2')}</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB3">{t('pricingStarterB3')}</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB4">{t('pricingStarterB4')}</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB5">{t('pricingStarterB5')}</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-cta"></span><span data-i18n="pricingStarterB6">{t('pricingStarterB6')}</span></li>
        </ul>
        <div class="mt-8">
          <button type="button" data-plan-trigger="starter" class="inline-flex items-center justify-center rounded-full border border-brand-cta/35 bg-white/75 px-8 py-3.5 text-base font-semibold text-brand-text shadow-[0_18px_36px_-24px_rgba(26,77,26,0.45)] transition-transform duration-300 hover:scale-[1.02] dark:bg-white/10 dark:text-brand-text-dark">
            <span data-i18n="pricingStarterCta">{t('pricingStarterCta')}</span>
          </button>
        </div>
      </div>

      <div class="pro-card">
        <div class="pro-card__inner">
          <div class="flex items-center justify-center gap-2 text-sm font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta-text-dark">
            <span data-i18n="pricingProLabel">{t('pricingProLabel')}</span>
            <span class="rounded-full pro-ribbon px-3 py-1 text-xs font-semibold shadow-lg" data-i18n="pricingProRibbon">{t('pricingProRibbon')}</span>
          </div>
          <div class="mt-5 text-3xl sm:text-5xl font-bold text-brand-cta-text dark:text-brand-text-dark">
            <span id="price-amount" data-base-usd="30" data-i18n="pricingProPrice">{t('pricingProPrice')}</span><span class="ml-1 align-top text-base font-normal text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingProPeriod">{t('pricingProPeriod')}</span>
          </div>
          <p class="mt-4 text-base text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingProBody">{t('pricingProBody')}</p>
          <ul class="mt-7 space-y-3 text-left text-sm leading-relaxed">
            <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 text-brand-cta" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span data-i18n="pricingProB1">{t('pricingProB1')}</span></li>
            <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 text-brand-cta" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span data-i18n="pricingProB2">{t('pricingProB2')}</span></li>
            <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 text-brand-cta" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span data-i18n="pricingProB3">{t('pricingProB3')}</span></li>
            <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 text-brand-cta" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span data-i18n="pricingProB4">{t('pricingProB4')}</span></li>
            <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 text-brand-cta" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span data-i18n="pricingProB5">{t('pricingProB5')}</span></li>
          </ul>
          <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
            <button type="button" data-plan-trigger="pro" class="inline-flex items-center justify-center rounded-full pro-cta px-9 py-3.5 text-lg font-semibold shadow-[0_28px_56px_-28px_rgba(26,77,26,0.55)] transition-transform duration-300 hover:scale-[1.03]">
              <span data-i18n="pricingProCta">{t('pricingProCta')}</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-card p-5 text-left text-brand-text dark:text-brand-text-dark self-start">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta-text-dark" data-i18n="pricingEnterpriseTitle">{t('pricingEnterpriseTitle')}</div>
          <span class="rounded-full bg-brand-cta/20 px-3 py-1 text-xs font-semibold text-brand-cta-text dark:text-brand-cta-text-dark" data-i18n="pricingEnterpriseRibbon">{t('pricingEnterpriseRibbon')}</span>
        </div>
  <h3 class="mt-3.5 text-2xl font-semibold" data-i18n="pricingEnterpriseHeading">{t('pricingEnterpriseHeading')}</h3>
  <p class="mt-3 text-sm sm:text-base leading-relaxed text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingEnterpriseBody">{t('pricingEnterpriseBody')}</p>
    <button type="button" data-contact-trigger="sales" class="group mt-7 inline-flex items-center gap-2 rounded-full border border-brand-cta/35 bg-white/75 px-6 py-3 text-sm font-semibold text-brand-text transition-colors duration-300 hover:bg-brand-cta/10 dark:bg-white/10 dark:text-brand-text-dark">
      <span data-i18n="pricingEnterpriseCta">{t('pricingEnterpriseCta')}</span>
          <svg class="h-4 w-4 dark:group-hover:text-brand-cta-text-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

  <div class="surface-card p-5 text-left text-brand-text dark:text-brand-text-dark">
    <div class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-cta-text dark:text-brand-cta-text-dark" data-i18n="pricingImplementTag">{t('pricingImplementTag')}</div>
  <h3 class="mt-3.5 text-2xl font-semibold" data-i18n="pricingImplementHeading">{t('pricingImplementHeading')}</h3>
  <p class="mt-3 text-sm sm:text-base leading-relaxed text-brand-text/70 dark:text-brand-text-dark/70" data-i18n="pricingImplementBody">{t('pricingImplementBody')}</p>
  <ul class="mt-3.5 space-y-2 text-sm text-brand-text/70 dark:text-brand-text-dark/70">
          <li>✔ <span data-i18n="pricingImplementB1">{t('pricingImplementB1')}</span></li>
          <li>✔ <span data-i18n="pricingImplementB2">{t('pricingImplementB2')}</span></li>
          <li>✔ <span data-i18n="pricingImplementB3">{t('pricingImplementB3')}</span></li>
        </ul>
        <div class="mt-4">
          <button type="button" data-contact-trigger="support" class="group mt-3 inline-flex items-center gap-2 rounded-full border border-brand-cta/35 bg-white/75 px-6 py-3 text-sm font-semibold text-brand-text transition-colors duration-300 hover:bg-brand-cta/10 dark:bg-white/10 dark:text-brand-text-dark">
            <span>{t('contactSupportBtn')}</span>
          </button>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
  <h3 class="text-2xl md:text-3xl font-semibold text-brand-text dark:text-brand-text-dark mb-5 max-w-3xl mx-auto leading-relaxed" data-i18n="pricingFinalHeading">{t('pricingFinalHeading')}</h3>
    <button type="button" data-plan-trigger="starter" class="inline-flex items-center justify-center rounded-full pro-cta px-9 py-3.5 text-lg font-semibold shadow-[0_28px_56px_-28px_rgba(26,77,26,0.6)] transition-transform duration-300 hover:scale-[1.03]">
    <span data-i18n="pricingFinalCta">{t('pricingFinalCta')}</span>
      </button>
    </div>

    <!-- FAQ placed before footer - render only when a named `faq` slot is provided -->
    {Astro.slots && Astro.slots.faq ? (
      <div class="mt-16">
        <slot name="faq" />
      </div>
    ) : null}

    
  </div>
</section>

<ContactWizard />

<script is:inline>
  (function () {
    const priceEl = document.getElementById('price-amount');
    if (!priceEl) return;
    const baseUSD = Number(priceEl.dataset.baseUsd || 30);
      const userLocale = (navigator.languages && navigator.languages[0]) || navigator.language || 'en-US';
    let lang = (userLocale && userLocale.split('-')[0]) || 'en';

    // Default mapping by language
    const langToCurrency = { en: 'USD', ko: 'KRW', ru: 'RUB', uz: 'UZS' };
    let currency = langToCurrency[lang] || 'USD';

    // Fallback rates used if exchange API is unavailable
    const fallbackRates = { KRW: 1400, UZS: 12175, RUB: 95 };

    // Pretty rounding for large numbers to make amounts look tidy
    function prettyPrice(v) {
      if (v >= 1000000) return Math.floor(v / 10000) * 10000;
      if (v >= 100000) return Math.floor(v / 1000) * 1000;
      if (v >= 10000) return Math.floor(v / 100) * 100;
      return Math.round(v);
    }

    // Locale-aware formatting
    function setDisplay(val) {
      try {
        const formatted = new Intl.NumberFormat(userLocale, { style: 'currency', currency, maximumFractionDigits: 0 }).format(val);
        priceEl.textContent = formatted;
      } catch (e) {
        const fallback = `${Math.round(val).toLocaleString()} ${currency}`;
        priceEl.textContent = fallback;
      }
    }

    // Use timezone detection as a stronger signal than browser language alone.
    // This ensures visitors in Uzbekistan (Asia/Tashkent) see UZS even if their browser lang is English.
    try {
      const tz = (Intl.DateTimeFormat && Intl.DateTimeFormat().resolvedOptions().timeZone) || '';
      const tzLower = String(tz).toLowerCase();
      if (/tashkent|uzbekistan|asia\/tashkent/.test(tzLower)) {
        currency = 'UZS';
        lang = 'uz';
      } else if (/seoul|korea|asia\/seoul/.test(tzLower)) {
        currency = 'KRW';
        lang = 'ko';
      } else if (/moscow|europe\/moscow|europe\/saint_petersburg|europe\/minsk/.test(tzLower)) {
        currency = 'RUB';
        lang = 'ru';
      }
    } catch (e) {}

    // If timezone didn't determine the currency, try region subtag from locale (e.g., en-US)
    if (!currency || currency === 'USD') {
      try {
        const parts = userLocale.split('-');
        const region = parts[1] ? parts[1].toUpperCase() : '';
        if (region === 'UZ') currency = 'UZS';
        else if (region === 'KR') currency = 'KRW';
        else if (region === 'RU' || region === 'BY') currency = 'RUB';
        // treat several english-speaking regions as USD by default
        else if (['US', 'GB', 'AU', 'CA', 'NZ'].includes(region)) currency = 'USD';
      } catch (e) {}
    }

    // If currency is still USD, just display USD and stop
    if (currency === 'USD') {
      setDisplay(baseUSD);
      return;
    }

    // Attempt to fetch latest rate, fallback to static rates if API fails
    const api = `https://api.exchangerate.host/convert?from=USD&to=${currency}&amount=${baseUSD}`;
    fetch(api, { cache: 'no-store' })
      .then((r) => r.json())
      .then((data) => {
        let converted = data && data.result ? data.result : null;
        if (!converted) {
          const rate = fallbackRates[currency] || 1;
          converted = baseUSD * rate;
        }
        setDisplay(prettyPrice(converted));
      })
      .catch(() => {
        const rate = fallbackRates[currency] || 1;
        const converted = baseUSD * rate;
        setDisplay(prettyPrice(converted));
      });
  })();
</script>
