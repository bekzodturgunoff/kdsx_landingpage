</header>
<script is:inline>
  (function setupHeader() {
    const LANGUAGE_STORAGE_KEY = "preferred-lang";
    const TRANSLATION_FALLBACK = "en";

    const supportedEl = document.getElementById('supported-langs');
    const supported = (function () {
      try { return supportedEl ? JSON.parse(supportedEl.textContent || '[]') : []; } catch (_) { return []; }
    })();

    const getPathLang = () => {
      const first = window.location.pathname.split("/").filter(Boolean)[0];
      return supported.includes(first) ? first : null;
    };

    const buildLocalizedPath = (lang) => {
      const segments = window.location.pathname.split("/").filter(Boolean);
      const hasLangPrefix = segments.length > 0 && supported.includes(segments[0]);
      const rest = hasLangPrefix ? segments.slice(1) : segments;
      return `/${lang}${rest.length ? `/${rest.join("/")}` : ""}`;
    };

    const applyLanguage = (lang, opts = { navigate: false }) => {
      const html = document.documentElement;
      html.setAttribute("lang", lang);
      try {
        localStorage.setItem(LANGUAGE_STORAGE_KEY, lang);
      } catch (_) {}
      document.cookie = `lang=${encodeURIComponent(lang)}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;
      document.querySelectorAll(".lang-select").forEach((select) => {
        if (select.value !== lang) {
          select.value = lang;
        }
      });

      if (opts.navigate) {
        const targetPath = buildLocalizedPath(lang);
        const currentPath = window.location.pathname;
        if (targetPath !== currentPath) {
          window.location.assign(`${targetPath}${window.location.search}${window.location.hash}`);
        }
      }
    };

    const bindLanguage = () => {
      const selects = document.querySelectorAll(".lang-select");
      if (!selects.length) return;

      selects.forEach((select) => {
        if ((select)._boundLang) return;
        select.addEventListener("change", (event) => {
          const target = event.target;
          const lang = target.value || TRANSLATION_FALLBACK;
          applyLanguage(lang, { navigate: true });
        });
        (select)._boundLang = true;
      });

      let storedLang;
      try {
        storedLang = localStorage.getItem(LANGUAGE_STORAGE_KEY);
      } catch (_) {
        storedLang = undefined;
      }
      const initialLang = getPathLang() || storedLang || document.documentElement.getAttribute("lang") || TRANSLATION_FALLBACK;
      applyLanguage(initialLang);
    };

    const bindTheme = () => {
  const html = document.documentElement;
  const THEME_KEY = 'theme'; // 'light' | 'dark'
      const DARK_COLOR = '#121212';
      const LIGHT_COLOR = '#ffffff';
      const COOKIE_MAX_AGE = 60 * 60 * 24 * 365; // 1 year

      const getCookieTheme = () => {
        const match = document.cookie.match(/(?:^|; )theme=([^;]+)/);
        return match ? decodeURIComponent(match[1]) : null;
      };

      const getStoredTheme = () => {
        let value;
        try {
          value = localStorage.getItem(THEME_KEY);
        } catch (_) {
          value = undefined;
        }
        if (!value) {
          const cookieValue = getCookieTheme();
          if (cookieValue) return cookieValue;
        }
        return (value === 'dark' || value === 'light') ? value : 'light';
      };

      const setStoredTheme = (value) => {
        try {
          localStorage.setItem(THEME_KEY, value);
        } catch (_) {}
        document.cookie = `theme=${encodeURIComponent(value)}; path=/; max-age=${COOKIE_MAX_AGE}; SameSite=Lax`;
      };

      const syncThemeArtifacts = (effective) => {
        // Update document chrome so mobile browsers respect the chosen theme
        html.setAttribute('data-theme', effective);
        html.style.colorScheme = effective === 'dark' ? 'dark' : 'light';

        const meta = document.querySelector('meta[name="theme-color"]');
        if (meta) {
          meta.setAttribute('content', effective === 'dark' ? DARK_COLOR : LIGHT_COLOR);
        }

        const colorSchemeMeta = document.querySelector('meta[name="color-scheme"]');
        if (colorSchemeMeta) {
          colorSchemeMeta.setAttribute('content', effective === 'dark' ? 'dark' : 'light');
        }

        // Update any theme-aware logos: use the provided light/dark sources
        try {
          document.querySelectorAll('img[data-logo-for-light]').forEach((img) => {
            const lightSrc = img.getAttribute('data-logo-for-light');
            const darkSrc = img.getAttribute('data-logo-for-dark');
            const chosen = effective === 'dark' ? (darkSrc || img.getAttribute('src')) : (lightSrc || img.getAttribute('src'));
            if (chosen && img.getAttribute('src') !== chosen) img.setAttribute('src', chosen);
          });
        } catch (_) {}
      };

      const applyTheme = (mode) => {
        const effective = (mode === 'dark' || mode === 'light') ? mode : 'dark';
        // Disable transitions during theme switch for instant change
        html.classList.add('theme-transitioning');
        if (effective === 'dark') html.classList.add('dark'); else html.classList.remove('dark');
        syncThemeArtifacts(effective);
        updateThemeUI(effective);
        // Re-enable transitions after a frame
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            html.classList.remove('theme-transitioning');
          });
        });
      };

      const updateThemeUI = (mode) => {
        document.querySelectorAll('[data-theme-option]').forEach((btn) => {
          const val = btn.getAttribute('data-theme-option');
          const active = val === mode;
          btn.classList.toggle('bg-brand-cta', active);
          btn.classList.toggle('text-brand-cta-text', active);
          btn.classList.toggle('shadow', active);
        });

        // Update compact cycle button icon and aria-label
        const cycleBtn = document.querySelector('[data-theme-cycle]');
        if (cycleBtn) {
          cycleBtn.setAttribute('aria-label', `Theme: ${mode}`);
          cycleBtn.querySelectorAll('[data-icon]')?.forEach((el) => {
            const show = el.getAttribute('data-icon') === mode;
            el.classList.toggle('hidden', !show);
            el.classList.toggle('block', show);
          });
        }
      };

      const current = getStoredTheme();
      applyTheme(current);

      // Bind segmented controls
      document.querySelectorAll('[data-theme-group]').forEach((group) => {
        if (group._boundTheme) return;
        group.addEventListener('click', (e) => {
          const target = e.target.closest('[data-theme-option]');
          if (!target) return;
          const val = target.getAttribute('data-theme-option');
          setStoredTheme(val);
          applyTheme(val);
        });
        group._boundTheme = true;
      });

      // Bind cycle button (mobile navbar)
      const cycleBtn = document.querySelector('[data-theme-cycle]');
      if (cycleBtn && !cycleBtn._boundThemeCycle) {
        cycleBtn.addEventListener('click', () => {
          const order = ['light', 'dark'];
          const current = getStoredTheme();
          const idx = Math.max(0, order.indexOf(current));
          const next = order[(idx + 1) % order.length];
          setStoredTheme(next);
          applyTheme(next);
        });
        cycleBtn._boundThemeCycle = true;
      }
    };

    const bindMenu = () => {
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuToggle && mobileMenu && !(menuToggle)._boundMenu) {
        menuToggle.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            menuToggle.setAttribute('aria-expanded', 'false');
            menuToggle.setAttribute('aria-label', 'Open menu');
          } else {
            mobileMenu.classList.remove('hidden');
            menuToggle.setAttribute('aria-expanded', 'true');
            menuToggle.setAttribute('aria-label', 'Close menu');
          }
        });
        (menuToggle)._boundMenu = true;
      }
    };

    // Initialize and restore language switching without page reload
    bindTheme();
    bindMenu();
    bindLanguage();
    // Smooth-scroll desktop anchors; mobile keeps normal navigation to pages
    (function bindDesktopScroll(){
      const anchors = document.querySelectorAll('nav[aria-label="Primary"] a[data-scroll]');
      anchors.forEach((a) => {
        if ((a)._boundScroll) return;
        a.addEventListener('click', (e) => {
          const isDesktop = window.matchMedia('(min-width: 768px)').matches;
          if (!isDesktop) return; // allow normal nav on mobile
          const href = a.getAttribute('href') || '';
          const hashIndex = href.indexOf('#');
          if (hashIndex === -1) return;
          const basePath = href.slice(0, hashIndex) || '/';
          const id = href.slice(hashIndex + 1);
          if (!id) return;
          if (basePath !== window.location.pathname) return;
          e.preventDefault();
          const target = document.getElementById(id);
          if (target) {
            // Account for sticky header height so the target is not obscured
            // and to avoid layout shifts when scrolled into view.
            try {
              const header = document.querySelector('header');
              const headerHeight = header ? header.getBoundingClientRect().height : 0;
              const offset = Math.max(0, Math.round(headerHeight + 8));
              const top = window.scrollY + target.getBoundingClientRect().top - offset;
              window.scrollTo({ top, behavior: 'smooth' });
            } catch (e) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        });
        (a)._boundScroll = true;
      });
    })();
    window.addEventListener('pageshow', () => {
      bindTheme();
      bindMenu();
      bindLanguage();
    });
  })();
</script>