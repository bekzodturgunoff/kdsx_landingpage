import logoDark from '../assets/logo_dark.png';
import logoLight from '../assets/logo_light.png';
import { Image } from 'astro:assets';

const languageOptions = LANGUAGE_OPTIONS;
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = SUPPORTED_LANGS.includes(pathSegments[0] || '') ? pathSegments[0] : 'en';
const t = createT(currentLang);
const localeBase = `/${currentLang}`;
const homeHref = localeBase;
const featuresHref = `${localeBase}#features`;
const pricingHref = `${localeBase}#pricing`;
const faqHref = `${localeBase}#faq`;
const featuresPageHref = `${localeBase}/features`;
const pricingPageHref = `${localeBase}/pricing`;
const faqPageHref = `${localeBase}/faq`;
