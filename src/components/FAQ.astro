---
import { createT, SUPPORTED_LANGS } from '../i18n';

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = SUPPORTED_LANGS.includes((pathSegments[0] || '') as (typeof SUPPORTED_LANGS)[number])
  ? pathSegments[0]
  : 'en';
const t = createT(currentLang);
---
<section id="faq" class="w-full px-2 sm:px-6 py-12 sm:py-20 text-brand-text">
  <div class="max-w-5xl mx-auto section-shell px-4 sm:px-8 md:px-10 py-10 sm:py-14 md:py-16">
    <!-- Header with minimal padding on mobile for maximum content space -->
    <div class="flex flex-col items-center text-center gap-3 sm:gap-6 px-2 sm:px-6">
      <span class="badge-pill" data-i18n="faqBadge">{t('faqBadge')}</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-brand-text dark:text-brand-text-dark leading-tight" data-i18n="faqHeading">
        {t('faqHeading')}
      </h2>
      <p class="max-w-2xl text-base sm:text-lg text-brand-text/70 dark:text-brand-text-dark/70 leading-relaxed" data-i18n="faqBody">
        {t('faqBody')}
      </p>
    </div>

    <!-- FAQ Grid: Single column on mobile, two columns on tablet+ -->
  <div class="mt-8 sm:mt-12 grid gap-3 sm:gap-6 grid-cols-1 md:grid-cols-2 px-2 sm:px-6">
      <!-- Q1 -->
      <div class="surface-card p-4 sm:p-6 text-left">
        <h3 class="text-base sm:text-lg font-semibold text-brand-text dark:text-brand-text-dark leading-snug" data-i18n="faqQ1">{t('faqQ1')}</h3>
        <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/75" data-i18n="faqA1">
          {t('faqA1')}
        </p>
      </div>

      <!-- Q2 -->
      <div class="surface-card p-4 sm:p-6 text-left">
        <h3 class="text-base sm:text-lg font-semibold text-brand-text dark:text-brand-text-dark leading-snug" data-i18n="faqQ2">{t('faqQ2')}</h3>
        <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/75" data-i18n="faqA2">
          {t('faqA2')}
        </p>
      </div>

      <!-- Q3 -->
      <div class="surface-card p-4 sm:p-6 text-left">
        <h3 class="text-base sm:text-lg font-semibold text-brand-text dark:text-brand-text-dark leading-snug" data-i18n="faqQ3">{t('faqQ3')}</h3>
        <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/75" data-i18n="faqA3">
          {t('faqA3')}
        </p>
      </div>

      <!-- Q4 -->
      <div class="surface-card p-4 sm:p-6 text-left">
        <h3 class="text-base sm:text-lg font-semibold text-brand-text dark:text-brand-text-dark leading-snug" data-i18n="faqQ4">{t('faqQ4')}</h3>
        <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/75" data-i18n="faqA4">
          {t('faqA4')}
        </p>
      </div>

      <!-- Q5 -->
      <div class="surface-card p-4 sm:p-6 text-left md:col-span-2">
        <h3 class="text-base sm:text-lg font-semibold text-brand-text dark:text-brand-text-dark leading-snug" data-i18n="faqQ5">{t('faqQ5')}</h3>
        <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/75" data-i18n="faqA5">
          {t('faqA5')}
        </p>
      </div>
    </div>
  </div>
</section>
