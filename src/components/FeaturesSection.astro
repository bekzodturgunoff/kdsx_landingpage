---
import { createT, SUPPORTED_LANGS } from '../i18n';
import { Image } from 'astro:assets';

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const currentLang = SUPPORTED_LANGS.includes((pathSegments[0] || '') as (typeof SUPPORTED_LANGS)[number])
  ? pathSegments[0]
  : 'en';
const t = createT(currentLang);
---
<section id="features" class="w-full px-2 sm:px-6 py-10 sm:py-16">
  <div class="max-w-6xl mx-auto section-shell px-4 sm:px-8 md:px-10 py-10 sm:py-14 md:py-16">
    <div class="flex flex-col items-start gap-4 sm:gap-5 text-left">
  <span class="badge-pill" data-i18n="featuresBadge">{t('featuresBadge')}</span>
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-brand-text dark:text-brand-text-dark" data-i18n="featuresHeading">{t('featuresHeading')}</h2>
  <p class="max-w-3xl text-base sm:text-lg leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="featuresBody">{t('featuresBody')}</p>
    </div>

  <div class="mt-7 sm:mt-10 space-y-6 sm:space-y-9">
      <div class="feature-panel overflow-hidden text-brand-text dark:text-brand-text-dark">
        <div class="relative">
          <div class="absolute -top-12 right-12 h-36 w-36 rounded-full bg-brand-cta/25 blur-3xl"></div>
          <Image
            src="/app_images/PC_MOCKUP_DASH_VIEW.png"
            alt="Operations dashboard displaying revenue, prep, and guest sentiment metrics"
            width={5620}
            height={4684}
            sizes="(max-width: 640px) 100vw, 1200px"
            class="block w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
  <div class="px-4 sm:px-6 pt-4 sm:pt-6 pb-6 sm:pb-7 md:pt-8">
          <div class="enterprise-ribbon" data-i18n="featuresCard1Tag">{t('featuresCard1Tag')}</div>
          <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold" data-i18n="featuresCard1Title">{t('featuresCard1Title')}</h3>
          <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="featuresCard1Body">{t('featuresCard1Body')}</p>
          <div class="mt-5 sm:mt-7 flex flex-wrap gap-2 sm:gap-4">
            <div class="enterprise-pill" >
              <span data-i18n="featuresCard1Pill1">{t('featuresCard1Pill1')}</span>
            </div>
            <div class="enterprise-pill" >
              <span data-i18n="featuresCard1Pill2">{t('featuresCard1Pill2')}</span>
            </div>
            <div class="enterprise-pill" >
              <span data-i18n="featuresCard1Pill3">{t('featuresCard1Pill3')}</span>
            </div>
          </div>
        </div>
      </div>

            <div class="feature-panel overflow-hidden text-left text-brand-text dark:text-brand-text-dark">
        <Image
          src="/app_images/TABLE_MOCKUP_POS_MENU_VIEW.png"
          alt="Table-side POS tablet presenting menu and modifiers"
          width={2710}
          height={1920}
          sizes="(max-width: 640px) 100vw, 1100px"
          class="block w-full object-cover"
          loading="lazy"
          decoding="async"
        />
  <div class="px-4 sm:px-6 pt-4 sm:pt-6 pb-6 sm:pb-8 md:pt-8">
            <div class="enterprise-ribbon" data-i18n="featuresCard2Tag">{t('featuresCard2Tag')}</div>
          <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold" data-i18n="featuresCard2Title">{t('featuresCard2Title')}</h3>
          <p class="mt-2 sm:mt-3 text-sm sm:text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="featuresCard2Body">{t('featuresCard2Body')}</p>
        </div>
      </div>

  
      <div class="feature-panel overflow-hidden text-left text-brand-text dark:text-brand-text-dark">
        <Image
          src="/app_images/TABLE_MOCKUP_KITCHEN_ORDER_VIEW.png"
          alt="Kitchen display tablet showing synchronized order queues"
          width={2710}
          height={1920}
          sizes="(max-width: 640px) 100vw, 1100px"
          class="block w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="px-6 pt-6 pb-8">
          <div class="enterprise-ribbon" data-i18n="featuresCard3Tag">{t('featuresCard3Tag')}</div>
          <h3 class="mt-4 text-2xl font-semibold" data-i18n="featuresCard3Title">{t('featuresCard3Title')}</h3>
          <p class="mt-3 text-base leading-relaxed text-brand-text/75 dark:text-brand-text-dark/70" data-i18n="featuresCard3Body">{t('featuresCard3Body')}</p>
        </div>
      </div>

      <!-- Mobile-only "Mobile service" panel removed per request -->
    </div>
  </div>
</section>
