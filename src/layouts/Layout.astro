---
import '../styles/global.css';
import WizardForm from '../components/WizardForm.astro';
import { Image } from 'astro:assets';
import { translations, DEFAULT_LANGUAGE, createT, SUPPORTED_LANGS, SupportedLang } from '../i18n';
import logoDark from '../assets/logo_dark.png';
import logoLight from '../assets/logo_light.png';

const supportedLangs = SUPPORTED_LANGS;

interface Props {
  lang?: string;
}

const { lang: propLang } = Astro.props as Props;
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathLang = supportedLangs.includes(pathSegments[0] as SupportedLang)
  ? (pathSegments[0] as SupportedLang)
  : undefined;
const activeLang = supportedLangs.includes((propLang || '') as SupportedLang)
  ? (propLang as SupportedLang)
  : pathLang || DEFAULT_LANGUAGE;
const t = createT(activeLang);

const remainderSegments = pathLang ? pathSegments.slice(1) : pathSegments;
const remainderPath = remainderSegments.join('/');
const localizedPath = (langCode: SupportedLang) =>
  `/${langCode}${remainderPath ? `/${remainderPath}` : ''}`;
const canonicalPath = localizedPath(activeLang);

const translationsJSON = JSON.stringify(translations);
const canonicalHref = Astro.site ? new URL(canonicalPath, Astro.site).toString() : canonicalPath;
const HONEYBADGER_KEY = import.meta.env.PUBLIC_HONEYBADGER_API_KEY || '';
const currentYear = new Date().getFullYear();
const localeBase = `/${activeLang}`;
---
<html lang={activeLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#ffffff" id="theme-color-meta" />
  <title>Octopos | Run every shift in sync</title>
  <meta name="description" content="All‑in‑one POS for modern restaurants. Automate orders, track spend in real time, and keep the floor and kitchen moving together—every shift." />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Octopos | Run every shift in sync" />
  <meta property="og:description" content="All‑in‑one POS for modern restaurants. Automate orders, track spend in real time, and keep the floor and kitchen moving together—every shift." />
  <meta property="og:url" content={canonicalHref} />
  <meta property="og:image" content={logoDark} />
  <meta property="og:image:alt" content="Octopos logo" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Octopos | Run every shift in sync" />
  <meta name="twitter:description" content="All‑in‑one POS for modern restaurants. Automate orders, track spend in real time, and keep the floor and kitchen moving together—every shift." />
  <meta name="twitter:image" content={logoDark} />
  <link rel="canonical" href={canonicalHref} />
  {supportedLangs.map((langCode) => (
    <link
      rel="alternate"
      hreflang={langCode}
      href={Astro.site ? new URL(localizedPath(langCode), Astro.site).toString() : localizedPath(langCode)}
    />
  ))}
  <link
    rel="alternate"
    hreflang="x-default"
    href={Astro.site ? new URL(localizedPath(DEFAULT_LANGUAGE), Astro.site).toString() : localizedPath(DEFAULT_LANGUAGE)}/>
      <link rel="icon" type="image/png" sizes="32x32" href={logoDark} />
      <link rel="icon" type="image/png" sizes="32x32" href={logoLight} media="(prefers-color-scheme: dark)" />
      <link rel="shortcut icon" href={logoDark} />
  <meta name="color-scheme" content="light" />
  <!-- JSON-LD Schema for Software Application -->
  {HONEYBADGER_KEY && (
    <>
      <script src="https://js.honeybadger.io/v6.12/honeybadger.min.js" async></script>
      <script is:inline>{`if (typeof Honeybadger !== 'undefined') { Honeybadger.configure({ apiKey: "${HONEYBADGER_KEY}", environment: "${import.meta.env.PROD ? 'production' : 'development'}" }); }`}</script>
    </>
  )}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Octopos",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web, iOS, Android",
    "description": "All-in-one restaurant POS system with dashboard management, point of sale, and kitchen display. Manage orders, inventory, staff, and finances from one connected platform.",
    "offers": {
      "@type": "Offer",
      "price": "30.00",
      "priceCurrency": "USD",
      "priceValidUntil": "2026-12-31"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "ratingCount": "150"
    },
    "author": {
      "@type": "Organization",
      "name": "Octopos",
      "url": "https://octopos.uz"
    },
    "featureList": [
      "Point of Sale (POS)",
      "Kitchen Display System",
      "Inventory Management",
      "Financial Reports",
      "Employee Management",
      "Multi-location Support",
      "Real-time Analytics"
    ]
  }
  </script>
  <script type="application/json" id="supported-langs" set:html={JSON.stringify(supportedLangs)}></script>
    <script is:inline>
      // Initialize language early.
      (function () {
        try {
          const LANG_KEY = 'preferred-lang';
          const supportedEl = document.getElementById('supported-langs');
          const supported = (function () {
            try {
              return supportedEl ? JSON.parse(supportedEl.textContent || '[]') : ['en'];
            } catch (_) { return ['en']; }
          })();
          const pathLang = (() => {
            const first = window.location.pathname.split('/').filter(Boolean)[0];
            return supported.includes(first) ? first : null;
          })();
          const getCookieLang = () => {
            const match = document.cookie.match(/(?:^|; )lang=([^;]+)/);
            return match ? decodeURIComponent(match[1]) : null;
          };
          let stored;
          try { stored = localStorage.getItem(LANG_KEY); } catch (_) { stored = undefined; }
          if (pathLang) stored = pathLang;
          if (!stored) stored = getCookieLang();

          // If user has not chosen a language, try inferring from timezone (helps when browser language differs)
          if (!stored) {
            try {
              const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
              if (/Seoul|Korea|Asia\/Seoul/i.test(tz)) stored = 'ko';
              else if (/Tashkent|Uzbekistan|Asia\/Tashkent/i.test(tz)) stored = 'uz';
              else if (/Moscow|Europe\/Moscow|Europe\/Minsk|Europe\/Saint_Petersburg/i.test(tz)) stored = 'ru';
            } catch (_) {}
          }

          if (!stored) stored = navigator.language?.slice(0, 2);
          const resolved = supported.includes(String(stored).toLowerCase()) ? String(stored).toLowerCase() : 'en';
          document.documentElement.setAttribute('lang', resolved);
          document.cookie = `lang=${encodeURIComponent(resolved)}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;
          try { localStorage.setItem(LANG_KEY, resolved); } catch (_) {}
        } catch (_) {}
      })();
    </script>
    <script is:inline>
      // Initialize theme early (only 'light' or 'dark', default to light)
      (function () {
        try {
          const THEME_KEY = 'theme';
          const DARK_COLOR = '#121212';
          const LIGHT_COLOR = '#ffffff';
          const getCookieTheme = () => {
            const match = document.cookie.match(/(?:^|; )theme=([^;]+)/);
            return match ? decodeURIComponent(match[1]) : null;
          };
          let stored;
          try { stored = localStorage.getItem(THEME_KEY); } catch (_) { stored = undefined; }
          if (!stored) stored = getCookieTheme();
          const resolved = stored === 'dark' ? 'dark' : 'light';
          if (resolved === 'dark') document.documentElement.classList.add('dark'); else document.documentElement.classList.remove('dark');
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.style.colorScheme = resolved === 'dark' ? 'dark' : 'light';
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', resolved === 'dark' ? DARK_COLOR : LIGHT_COLOR);
          const colorSchemeMeta = document.querySelector('meta[name="color-scheme"]');
          if (colorSchemeMeta) colorSchemeMeta.setAttribute('content', resolved === 'dark' ? 'dark' : 'light');
          document.cookie = `theme=${encodeURIComponent(resolved)}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-brand-bg dark:bg-brand-bg-dark text-brand-text dark:text-brand-text-dark font-sans antialiased">
  <script type="application/json" id="translations-data" data-fallback={DEFAULT_LANGUAGE} set:html={translationsJSON}></script>
  <slot />

  <!-- Site footer (moved from PricingTable for consistent layout) -->
  <div class="max-w-6xl mx-auto section-shell px-4 sm:px-9 py-12 sm:py-14">
    <footer class="hidden md:block mt-8 pt-2 text-brand-text dark:text-brand-text-dark" aria-label="Site footer">
      <div>
      <div class="flex flex-col lg:flex-row justify-between items-start gap-6 mb-6">
        <div class="flex flex-col items-start">
          <div class="flex items-center gap-2 mb-2">
            <Image src={logoDark} alt="Octopos Logo" class="w-8 h-8 md:w-8 md:h-8 mr-2" loading="lazy" data-logo-for-light={logoDark?.src ?? logoDark} data-logo-for-dark={logoLight?.src ?? logoLight} width={32} height={32} />
            <span class="hidden md:inline-block font-bold text-2xl text-brand-text dark:text-brand-text-dark">Octopos</span>
          </div>
          <p class="text-sm opacity-75 max-w-xs" data-i18n="footerBrandDescription">{t('footerBrandDescription')}</p>
        </div>

        <div class="hidden md:flex flex-col items-start">
          <h4 class="font-semibold text-brand-text dark:text-brand-text-dark mb-4" data-i18n="footerContactTitle">{t('footerContactTitle')}</h4>
          <div class="space-y-3">
            <a href="tel:+998941500330" class="flex items-center gap-3 text-brand-text dark:text-brand-text-dark">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <span class="text-sm" data-i18n="footerContactPhone1">{t('footerContactPhone1')}</span>
            </a>
            <a href="tel:+998501886669" class="flex items-center gap-3 text-brand-text dark:text-brand-text-dark">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <span class="text-sm" data-i18n="footerContactPhone2">{t('footerContactPhone2')}</span>
            </a>
            <a href={`mailto:${t('footerContactEmail')}`} class="flex items-center gap-3 text-brand-text dark:text-brand-text-dark">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <span class="text-sm" data-i18n="footerContactEmail">{t('footerContactEmail')}</span>
            </a>
          </div>
        </div>

        <div class="flex flex-col items-start">
          <h4 class="font-semibold text-brand-text dark:text-brand-text-dark mb-4" data-i18n="footerFollowTitle">{t('footerFollowTitle')}</h4>
          <div class="flex gap-4">
            <a href="https://t.me/octopos_pos_uzbekistan" class="p-2 rounded-lg hover:bg-brand-cta hover:text-brand-cta-text transition-all" aria-label="Telegram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </a>
            <a href="https://www.youtube.com/@OctoposPOS-RestoranAvtomatlash" class="p-2 rounded-lg hover:bg-brand-cta hover:text-brand-cta-text transition-all" aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.instagram.com/octopos.uz" class="p-2 rounded-lg hover:bg-brand-cta hover:text-brand-cta-text transition-all" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          </div>
        </div>

        <div class="items-start" aria-label="Footer menu">
          <h4 class="font-semibold text-brand-text dark:text-brand-text-dark mb-4" data-i18n="footerQuickLinksTitle">{t('footerQuickLinksTitle')}</h4>
          <div class="flex flex-col space-y-2 text-sm">
            <a href={`${localeBase}/terms`} class="hover:text-brand-cta transition-colors" data-i18n="footerQuickLinkTerms">{t('footerQuickLinkTerms')}</a>
            <a href={`${localeBase}/privacy`} class="hover:text-brand-cta transition-colors" data-i18n="footerQuickLinkPrivacy">{t('footerQuickLinkPrivacy')}</a>
          </div>
        </div>
      </div>

      <div class="pt-4 flex flex-col md:flex-row justify-between items-center gap-4 text-sm opacity-75">
        <span>&copy; {currentYear} Octopos. <span data-i18n="footerRightsReserved">{t('footerRightsReserved')}</span></span>
        <span data-i18n="footerAccessibility">{t('footerAccessibility')}</span>
      </div>
    </div>
  </footer>
  </div>
    
    <!-- Floating CTA Button (Mobile Only) - Must be before WizardForm for event binding -->
    <div id="floating-cta" class="fixed bottom-6 left-4 right-4 z-50 md:hidden opacity-0 translate-y-4 pointer-events-none transition-all duration-300">
      <button data-plan-trigger="starter" class="w-full btn-solid py-4 text-base font-semibold shadow-lg shadow-brand-cta/30 flex items-center justify-center gap-2">
        <span data-i18n="pricingStarterCta">{t('pricingStarterCta')}</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    
    <WizardForm />
    
    <script is:inline>
      // Floating CTA visibility on scroll
      (function() {
        const floatingCta = document.getElementById('floating-cta');
        if (!floatingCta) return;
        
        let lastScrollY = 0;
        let ticking = false;
        
        const updateFloatingCta = () => {
          const scrollY = window.scrollY;
          const windowHeight = window.innerHeight;
          const docHeight = document.documentElement.scrollHeight;
          
          // Show after scrolling down 300px, hide near bottom
          const shouldShow = scrollY > 300 && scrollY < (docHeight - windowHeight - 200);
          
          if (shouldShow) {
            floatingCta.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
            floatingCta.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
          } else {
            floatingCta.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
            floatingCta.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
          }
          
          lastScrollY = scrollY;
          ticking = false;
        };
        
        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(updateFloatingCta);
            ticking = true;
          }
        }, { passive: true });
      })();
    </script>

    <script is:inline>
      // Ensure page starts at top on refresh
      if (history.scrollRestoration) {
        history.scrollRestoration = 'manual';
      }
      window.addEventListener('beforeunload', function() {
        window.scrollTo(0, 0);
      });
    </script>
  </body>
</html>
