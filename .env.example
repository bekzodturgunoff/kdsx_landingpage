# Copy this file to `.env` and fill in the values before running locally or deploying

# Required for sending wizard submissions via Resend
RESEND_API_KEY=
# Tip: strip any accidental trailing spaces or punctuation (e.g. semicolons)

# Must be a verified sender in Resend (e.g. notifications@kdsx.app).
# While testing you can use onboarding@resend.dev without verifying a domain.
FROM_EMAIL=onboarding@resend.dev

# Comma-separated recipients for lead notifications
TO_EMAIL=bekzodturgunoff@gmail.com

# Instant trial signup endpoints
PUBLIC_TRIAL_API_BASE_URL=http://localhost:3000
PUBLIC_DASH_APP_URL=http://localhost:5173
PUBLIC_KITCHEN_APP_URL=http://localhost:5174
PUBLIC_POS_APP_URL=http://localhost:5175
